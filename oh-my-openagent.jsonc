      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        { "model": "minimax-cn-coding-plan/MiniMax-M3" },
        { "model": "opencode-go/deepseek-v4-flash" }
      ],
      "skills": [
        "source-driven-development",
        "debugging-and-error-recovery",
        "api-and-interface-design"
      ]
    },
    "momus": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        { "model": "minimax-cn-coding-plan/MiniMax-M3" },
        { "model": "opencode-go/deepseek-v4-flash" }
      ],
      "skills": []
    },
    "explore": {
