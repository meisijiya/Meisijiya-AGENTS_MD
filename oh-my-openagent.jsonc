      ],
      "skills": ["source-driven-development"]
    },
    "multimodal-looker": {
      "model": "minimax-cn-coding-plan/MiniMax-M3",
      "fallback_models": [
        { "model": "opencode-go/deepseek-v4-pro" },
        { "model": "opencode-go/deepseek-v4-flash" }
      ],
      "skills": []
    },
    "sisyphus-junior": {
      "model": "minimax-cn-coding-plan/MiniMax-M3",
      "fallback_models": [
        { "model": "opencode-go/deepseek-v4-pro" },
        { "model": "opencode-go/deepseek-v4-flash" }
      ],
      "skills": ["incremental-implementation", "test-driven-development"]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "minimax-cn-coding-plan/MiniMax-M3",
      "fallback_models": [
        { "model": "opencode-go/deepseek-v4-pro" },
        { "model": "opencode-go/deepseek-v4-flash" }
      ]
    },
    "ultrabrain": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        { "model": "minimax-cn-coding-plan/MiniMax-M3" },
        { "model": "opencode-go/deepseek-v4-flash" }
      ]
    },
    "deep": {
      "model": "minimax-cn-coding-plan/MiniMax-M3",
      "fallback_models": [
        { "model": "opencode-go/deepseek-v4-pro" },
        { "model": "opencode-go/deepseek-v4-flash" }
      ]
    },
    "artistry": {
      "model": "minimax-cn-coding-plan/MiniMax-M3",
      "fallback_models": [
        { "model": "opencode-go/deepseek-v4-pro" },
        { "model": "opencode-go/deepseek-v4-flash" }
      ]
    },
    "writing": {
      "model": "minimax-cn-coding-plan/MiniMax-M3",
      "fallback_models": [
        { "model": "opencode-go/deepseek-v4-pro" },
        { "model": "opencode-go/deepseek-v4-flash" }
      ]
    },
    "quick": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        { "model": "minimax-cn-coding-plan/MiniMax-M3" },
        { "model": "opencode-go/deepseek-v4-pro" }
      ]
    },
    "unspecified-low": {
      "model": "minimax-cn-coding-plan/MiniMax-M3",
      "fallback_models": [
        { "model": "opencode-go/deepseek-v4-flash" },
        { "model": "opencode-go/deepseek-v4-pro" }
      ]
    },
    "unspecified-high": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        { "model": "minimax-cn-coding-plan/MiniMax-M3" },
        { "model": "opencode-go/deepseek-v4-flash" }
      ]
    }
  },

  "team_mode": {
    "enabled": true,
    "max_parallel_members": 4,
    "max_members": 8,
    "tmux_visualization": true,
    "max_wall_clock_minutes": 90,
    "max_member_turns": 300,
    "max_messages_per_run": 5000,
    "base_dir": "~/.omo",
    "message_payload_max_bytes": 32768,
    "recipient_unread_max_bytes": 262144,
    "mailbox_poll_interval_ms": 3000
  },

  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 180000,
    "providerConcurrency": {
      "minimax-cn-coding-plan": 3,
      "opencode-go": 8
    },
    "modelConcurrency": {
      "minimax-cn-coding-plan/MiniMax-M3": 3,
      "opencode-go/deepseek-v4-pro": 3,
      "opencode-go/deepseek-v4-flash": 12
    }
  },

  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },

  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [429, 500, 502, 503, 504],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },

  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  },

  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true
  }
}
